<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>ai.openclaw.rescue</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/adamcastro/.openclaw/workspace/openclaw-rescue/openclaw-rescue.sh</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/adamcastro/.openclaw</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    </dict>

    <key>KeepAlive</key>
    <true/>

    <key>RunAtLoad</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/Users/adamcastro/.openclaw/logs/rescue.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/adamcastro/.openclaw/logs/rescue.log</string>

    <key>ThrottleInterval</key>
    <integer>30</integer>

    <key>SessionCreate</key>
    <true/>
</dict>
</plist>
